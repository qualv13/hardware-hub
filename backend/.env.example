# Copy to .env and fill in. The app runs without these (sensible dev defaults).
DATABASE_URL=sqlite:///./hardware_hub.db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Bootstrap admin (created on first start; the ONLY way new accounts are made
# afterwards is via the Admin Panel — there is no self-registration).
ADMIN_EMAIL=admin@booksy.com
ADMIN_PASSWORD=admin123

# Allowed login email domain ("company domain only"). Empty = allow any.
ALLOWED_EMAIL_DOMAIN=booksy.com

# Gemini (AI Studio free key). Leave empty to use deterministic fallbacks.
# Free-tier models that support tools/function calling: gemini-2.5-flash
# (default), gemini-2.5-flash-lite, gemini-3-flash-preview.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
