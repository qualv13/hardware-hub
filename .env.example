# Copy to ".env" (next to docker-compose.yml) to configure the container.
# docker compose automatically loads this file. All values are optional.

# Enable real Gemini tool-calling (free-tier key from Google AI Studio).
# Leave empty to use the built-in deterministic fallbacks.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Admin bootstrap (created on first start; the only way new accounts are made).
ADMIN_EMAIL=admin@booksy.com
ADMIN_PASSWORD=admin123

# Login domain enforcement and JWT signing key.
ALLOWED_EMAIL_DOMAIN=booksy.com
SECRET_KEY=change-me-in-production
